{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_ENABLE_SUPABASE_AUTH": "true",
    "VITE_FORCE_BOOTSTRAP_CLOUD_SYNC": "false"
  },
  "rewrites": [
    {
      "source": "/:path((?!.*\\.).*)*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
